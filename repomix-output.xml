            resetCourierDraft();
          } else {
            resetTaxiDraft();
          }
          changeState('IDLE');
        }}
        loading={loading}
        comment={comment}
        setComment={setComment}
        stops={stops}
        onAddStop={() => {
          if (!toAddress || !toCoord) {
            Alert.alert('Сначала укажите адрес', 'Сначала выберите, куда едем, а потом добавляйте заезд.');
            return;
          }

          setIsStopSelectionMode(true);
          setSearchMode('stop');
          changeState('SEARCH');
