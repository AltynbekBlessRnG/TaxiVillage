        translateY={orderSheetTranslateY}
        serviceType={activeService === 'Курьер' ? 'courier' : 'taxi'}
        fromAddress={fromAddress}
        toAddress={toAddress}
        price={offeredPrice}
        setPrice={setOfferedPrice}
        onOrder={handleCreateRide}
        onEditAddress={() => changeState('SEARCH')}
        onSwipeDown={() => {
