              <View style={styles.courierRow}>
                <TextInput
                  style={[styles.courierInput, styles.courierInputHalf]}
                  placeholder="Вес"
                  placeholderTextColor="#71717A"
                  value={packageWeight}
                  onChangeText={(text) => setPackageWeight?.(text)}
                />
                <TextInput
                  style={[styles.courierInput, styles.courierInputHalf]}
