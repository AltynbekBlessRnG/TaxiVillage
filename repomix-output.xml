INSERT INTO "ChatMessage" (
  "id",
  "createdAt",
  "readAt",
  "intercityOrderId",
  "intercityBookingId",
  "senderUserId",
  "receiverUserId",
  "senderType",
  "receiverType",
  "content"
)
SELECT
  im."id",
  im."createdAt",
  im."readAt",
  im."intercityOrderId",
  im."intercityBookingId",
  im."senderUserId",
  im."receiverUserId",
  im."senderType",
  im."receiverType",
  im."content"
FROM "IntercityMessage" im;

DROP TABLE IF EXISTS "IntercityMessage";
DROP TABLE IF EXISTS "Message";
