  modalInput: { backgroundColor: '#09090B', color: '#fff', borderRadius: 12, padding: 15, fontSize: 16, minHeight: 80, textAlignVertical: 'top', borderWidth: 1, borderColor: '#27272A', marginBottom: 20 },
