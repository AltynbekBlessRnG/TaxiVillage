                  setActiveService(service);
                  if (service === 'Курьер') {
                    resetTaxiDraft();
                  } else if (service === 'Еда') {
                    navigation.navigate('FoodHome');
                  } else if (service === 'Межгород') {
                    navigation.navigate('IntercityHome');
                  } else if (service === 'Такси') {
