                    <td>
                      <span className={`badge badge-${d.status.toLowerCase()}`}>
                        {d.status === 'APPROVED' ? '✓ Одобрен' : d.status === 'REJECTED' ? '✕ Отклонен' : '⏳ Ожидает'}
