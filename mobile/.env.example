EXPO_PUBLIC_API_URL=http://192.168.0.10:3000/api
EXPO_PUBLIC_EAS_PROJECT_ID=your-expo-project-id
# Google Maps key will still be bundled in the client app.
# Restrict it in Google Cloud Console to your Android/iOS application IDs.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
