{
  "name": "taxivillage-backend",
  "version": "0.1.0",
  "description": "Backend API for TaxiVillage city taxi application (NestJS + Prisma + PostgreSQL).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test,scripts}/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"{src,test,scripts}/**/*.{ts,js,json}\"",
    "start": "node dist/main.js",
    "start:dev": "node scripts/with-env.js ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "node scripts/with-env.js jest --config jest.e2e.config.js --runInBand --forceExit",
    "test:e2e:watch": "node scripts/with-env.js jest --config jest.e2e.config.js --watch",
    "socket:load": "node scripts/with-env.js node scripts/socket-load.js",
    "taxi-dispatch-soak": "node scripts/with-env.js node scripts/taxi-dispatch-soak.js",
    "prisma:migrate:deploy": "node scripts/with-env.js npx prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:validate": "node scripts/prisma-validate.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@prisma/client": "^5.16.0",
    "@sentry/node": "^8.55.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.1",
    "multer": "^2.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.16.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  }
}
