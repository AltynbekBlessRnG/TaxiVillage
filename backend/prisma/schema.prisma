generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Общий пользователь системы
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phone     String   @unique
  email     String?  @unique
  password  String
  phoneVerifiedAt DateTime?
  refreshTokenHash String?
  pushToken String?
  avatarUrl String?
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  /// passenger | driver | admin
  role      UserRole

  passenger PassengerProfile?
  driver    DriverProfile?
  merchant  Merchant?
  sentChatMessages ChatMessage[] @relation("SentChatMessages")
  receivedChatMessages ChatMessage[] @relation("ReceivedChatMessages")
}

model PhoneOtpSession {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  phone            String
  code             String
  expiresAt        DateTime
  attempts         Int             @default(0)
  usedAt           DateTime?
  verifiedAt       DateTime?
  verificationToken String?        @unique
  telegramChatId   String?
  telegramDeliveredAt DateTime?
  channel          PhoneOtpChannel @default(TELEGRAM)
  purpose          PhoneOtpPurpose
  payload          Json?

  @@index([phone, purpose])
  @@index([expiresAt])
}

/// Профиль пассажира
model PassengerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  fullName  String?

  rides     Ride[]   @relation("PassengerRides")
  courierOrders CourierOrder[] @relation("PassengerCourierOrders")
  foodOrders FoodOrder[] @relation("PassengerFoodOrders")
  intercityOrders IntercityOrder[] @relation("PassengerIntercityOrders")
  intercityBookings IntercityBooking[] @relation("PassengerIntercityBookings")
  favoriteAddresses FavoriteAddress[]
}

/// Профиль водителя
model DriverProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])

  fullName     String?
  status       DriverStatus  @default(PENDING) // PENDING / APPROVED / REJECTED
  isOnline     Boolean       @default(false)
  supportsTaxi Boolean       @default(true)
  supportsCourier Boolean    @default(false)
  supportsIntercity Boolean  @default(false)
  driverMode   DriverMode    @default(TAXI)
  courierTransportType CourierTransportType?

  lat          Float?
  lng          Float?
  lastRideFinishedAt DateTime?
  lastCourierOrderFinishedAt DateTime?
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  rating       Float         @default(5.0)

  car          Car?
  rides        Ride[]        @relation("DriverRides")
  courierOrders CourierOrder[] @relation("CourierOrders")
  intercityOrders IntercityOrder[] @relation("IntercityDriverOrders")
  intercityTrips IntercityTrip[] @relation("DriverIntercityTrips")
  documents    DriverDocument[]
}

/// Заведение / merchant profile
model Merchant {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id])

  name        String
  whatsAppPhone String?
  cuisine     String?
  description String?
  etaMinutes  Int           @default(35)
  minOrder    Decimal       @default(0) @db.Decimal(10, 2)
  rating      Float         @default(5.0)
  isOpen      Boolean       @default(true)
  tone        String?       @default("#7C2D12")
  coverImageUrl String?

  menuCategories MenuCategory[]
  foodOrders     FoodOrder[] @relation("MerchantFoodOrders")
}


/// Автомобиль водителя
model Car {
  id           String         @id @default(cuid())
  driverId     String         @unique
  driver       DriverProfile  @relation(fields: [driverId], references: [id])

  make         String
  model        String
  color        String
  plateNumber  String
}

/// Документы водителя (права, СТС, лицензия и т.п.)
model DriverDocument {
  id          String         @id @default(cuid())
  driverId    String
  driver      DriverProfile  @relation(fields: [driverId], references: [id])

  type        DocumentType
  url         String
  uploadedAt  DateTime       @default(now())
  approved    Boolean        @default(false)
}

/// Тариф
model Tariff {
  id               String   @id @default(cuid())
  name             String
  baseFare         Decimal  @db.Decimal(10, 2) // базовая стоимость посадки
  pricePerKm       Decimal  @db.Decimal(10, 2)
  pricePerMinute   Decimal? @db.Decimal(10, 2)

  systemCommissionPercent Int @default(10)

  isActive         Boolean  @default(true)

  rides            Ride[]
}

/// Поездка
model Ride {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  passengerId      String
  passenger        PassengerProfile @relation("PassengerRides", fields: [passengerId], references: [id])

  driverId         String?
  driver           DriverProfile?   @relation("DriverRides", fields: [driverId], references: [id])

  tariffId         String
  tariff           Tariff          @relation(fields: [tariffId], references: [id])

  status           RideStatus      @default(SEARCHING_DRIVER)

  paymentMethod    PaymentMethod    @default(CARD)

  fromAddress      String
  fromLat          Float
  fromLng          Float
  pickupLocationPrecision AddressPrecision @default(EXACT)

  toAddress        String
  toLat            Float
  toLng            Float
  dropoffLocationPrecision AddressPrecision @default(EXACT)

  comment          String?

  // Промежуточные остановки
  stops            RideStop[]

  estimatedPrice   Decimal?        @db.Decimal(10, 2)
  finalPrice       Decimal?        @db.Decimal(10, 2)

  startedAt        DateTime?
  finishedAt       DateTime?

  commissionAmount Decimal?        @db.Decimal(10, 2)
  driverRating     Int?

  statusHistory    RideStatusHistory[]
  messages        ChatMessage[]
}

/// Остановка поездки
model RideStop {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])

  address   String
  lat       Float
  lng       Float

  createdAt DateTime @default(now())
}

/// История изменения статусов поездки
model RideStatusHistory {
  id        String      @id @default(cuid())
  rideId    String
  ride      Ride        @relation(fields: [rideId], references: [id])

  status    RideStatus
  createdAt DateTime    @default(now())
}

enum UserRole {
  PASSENGER
  DRIVER
  COURIER
  DRIVER_INTERCITY
  MERCHANT
  ADMIN
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DriverMode {
  TAXI
  COURIER
  INTERCITY
}

enum CourierTransportType {
  CAR
  BIKE
  FOOT
}

enum RideStatus {
  SEARCHING_DRIVER
  DRIVER_ASSIGNED
  ON_THE_WAY
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CourierOrderStatus {
  SEARCHING_COURIER
  TO_PICKUP
  COURIER_ARRIVED
  TO_RECIPIENT
  PICKED_UP
  DELIVERING
  DELIVERED
  CANCELED
}

enum FoodOrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  ON_DELIVERY
  DELIVERED
  CANCELED
}

enum IntercityOrderStatus {
  SEARCHING_DRIVER
  CONFIRMED
  DRIVER_EN_ROUTE
  BOARDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum IntercityTripStatus {
  PLANNED
  BOARDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum IntercityBookingStatus {
  CONFIRMED
  BOARDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum IntercityTripInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum IntercityBookingType {
  SEAT
  FULL_CABIN
}

enum DocumentType {
  DRIVER_LICENSE
  CAR_REGISTRATION
  TAXI_LICENSE
  COURIER_ID
  OTHER
}

enum MessageSender {
  PASSENGER
  DRIVER
}

enum PaymentMethod {
  CARD
  CASH
}

enum PhoneOtpChannel {
  TELEGRAM
}

enum PhoneOtpPurpose {
  REGISTER
  LOGIN
}

enum AddressPrecision {
  EXACT
  LANDMARK_TEXT
}

/// Избранные адреса пассажира
model FavoriteAddress {
  id          String   @id @default(cuid())
  passengerId String
  passenger   PassengerProfile @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  
  name        String   // "Дом", "Работа", "Спортзал"
  address     String   // Полный адрес
  lat         Float
  lng         Float
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([passengerId, name])
}

model ChatMessage {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  readAt             DateTime?
  messageGroupId     String?

  rideId             String?
  ride               Ride?             @relation(fields: [rideId], references: [id])

  intercityOrderId   String?
  intercityOrder     IntercityOrder?   @relation("IntercityOrderMessages", fields: [intercityOrderId], references: [id])

  intercityBookingId String?
  intercityBooking   IntercityBooking? @relation("IntercityBookingMessages", fields: [intercityBookingId], references: [id])

  intercityTripId    String?
  intercityTrip      IntercityTrip?    @relation("IntercityTripMessages", fields: [intercityTripId], references: [id])

  senderUserId       String
  senderUser         User              @relation("SentChatMessages", fields: [senderUserId], references: [id])
  receiverUserId     String
  receiverUser       User              @relation("ReceivedChatMessages", fields: [receiverUserId], references: [id])

  senderType         MessageSender
  receiverType       MessageSender
  content            String

  @@index([rideId, createdAt])
  @@index([intercityOrderId, createdAt])
  @@index([intercityBookingId, createdAt])
  @@index([intercityTripId, createdAt])
}

/// Курьерский заказ
model CourierOrder {
  id               String              @id @default(cuid())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  passengerId      String
  passenger        PassengerProfile    @relation("PassengerCourierOrders", fields: [passengerId], references: [id])

  courierId        String?
  courier          DriverProfile?      @relation("CourierOrders", fields: [courierId], references: [id])

  status           CourierOrderStatus  @default(SEARCHING_COURIER)
  paymentMethod    PaymentMethod       @default(CARD)

  pickupAddress    String
  pickupLat        Float
  pickupLng        Float

  dropoffAddress   String
  dropoffLat       Float
  dropoffLng       Float

  itemDescription  String
  packageWeight    String?
  packageSize      String?
  comment          String?

  estimatedPrice   Decimal?            @db.Decimal(10, 2)
  finalPrice       Decimal?            @db.Decimal(10, 2)

  arrivedAt        DateTime?
  pickedUpAt       DateTime?
  deliveredAt      DateTime?

  statusHistory    CourierOrderStatusHistory[]
}

/// История изменения статусов курьерского заказа
model CourierOrderStatusHistory {
  id             String             @id @default(cuid())
  courierOrderId String
  courierOrder   CourierOrder       @relation(fields: [courierOrderId], references: [id])

  status         CourierOrderStatus
  createdAt      DateTime           @default(now())
}

model MenuCategory {
  id          String     @id @default(cuid())
  merchantId  String
  merchant    Merchant   @relation(fields: [merchantId], references: [id])

  name        String
  sortOrder   Int        @default(0)

  items       MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])

  name        String
  sortOrder   Int          @default(0)
  description String?
  price       Decimal      @db.Decimal(10, 2)
  isAvailable Boolean      @default(true)
  imageUrl    String?

  foodOrderItems FoodOrderItem[]
}

model FoodOrder {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  passengerId     String
  passenger       PassengerProfile @relation("PassengerFoodOrders", fields: [passengerId], references: [id])

  merchantId      String
  merchant        Merchant         @relation("MerchantFoodOrders", fields: [merchantId], references: [id])

  status          FoodOrderStatus  @default(PLACED)
  deliveryAddress String
  comment         String?
  paymentMethod   PaymentMethod    @default(CARD)
  totalPrice      Decimal          @db.Decimal(10, 2)

  items           FoodOrderItem[]
  statusHistory   FoodOrderStatusHistory[]
}

model FoodOrderItem {
  id          String    @id @default(cuid())
  foodOrderId String
  foodOrder   FoodOrder @relation(fields: [foodOrderId], references: [id])

  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])

  name        String
  price       Decimal   @db.Decimal(10, 2)
  qty         Int
}

model FoodOrderStatusHistory {
  id          String          @id @default(cuid())
  foodOrderId String
  foodOrder   FoodOrder       @relation(fields: [foodOrderId], references: [id])

  status      FoodOrderStatus
  createdAt   DateTime        @default(now())
}

model IntercityOrder {
  id                String               @id @default(cuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  passengerId       String
  passenger         PassengerProfile     @relation("PassengerIntercityOrders", fields: [passengerId], references: [id])

  driverId          String?
  driver            DriverProfile?     @relation("IntercityDriverOrders", fields: [driverId], references: [id])

  status            IntercityOrderStatus @default(SEARCHING_DRIVER)
  paymentMethod     PaymentMethod        @default(CARD)

  fromCity          String
  toCity            String
  departureAt       DateTime
  seats             Int                  @default(1)
  baggage           String?
  comment           String?
  price             Decimal              @db.Decimal(10, 2)
  stops             Json?
  womenOnly         Boolean              @default(false)
  baggageRequired   Boolean              @default(false)
  noAnimals         Boolean              @default(false)

  statusHistory     IntercityOrderStatusHistory[]
  messages          ChatMessage[]        @relation("IntercityOrderMessages")
  invites           IntercityTripInvite[]
}

model IntercityOrderStatusHistory {
  id                String               @id @default(cuid())
  intercityOrderId  String
  intercityOrder    IntercityOrder       @relation(fields: [intercityOrderId], references: [id])

  status            IntercityOrderStatus
  createdAt         DateTime             @default(now())
}

model IntercityTrip {
  id                String               @id @default(cuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  driverId          String
  driver            DriverProfile        @relation("DriverIntercityTrips", fields: [driverId], references: [id])

  fromCity          String
  toCity            String
  departureAt       DateTime
  pricePerSeat      Decimal              @db.Decimal(10, 2)
  seatCapacity      Int
  comment           String?
  stops             Json?
  womenOnly         Boolean              @default(false)
  baggageSpace      Boolean              @default(true)
  allowAnimals      Boolean              @default(true)

  carMake           String?
  carModel          String?
  carColor          String?
  plateNumber       String?

  status            IntercityTripStatus  @default(PLANNED)

  bookings          IntercityBooking[]
  statusHistory     IntercityTripStatusHistory[]
  messages          ChatMessage[]         @relation("IntercityTripMessages")
  invites           IntercityTripInvite[]
}

model IntercityBooking {
  id                String                @id @default(cuid())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tripId            String
  trip              IntercityTrip         @relation(fields: [tripId], references: [id])

  passengerId       String
  passenger         PassengerProfile      @relation("PassengerIntercityBookings", fields: [passengerId], references: [id])

  bookingType       IntercityBookingType  @default(SEAT)
  seatsBooked       Int                   @default(1)
  totalPrice        Decimal               @db.Decimal(10, 2)
  comment           String?
  status            IntercityBookingStatus @default(CONFIRMED)
  messages          ChatMessage[]         @relation("IntercityBookingMessages")

  @@index([tripId, status])
  @@index([passengerId, status])
  @@unique([tripId, passengerId, status])
}

model IntercityTripInvite {
  id           String                   @id @default(cuid())
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  respondedAt  DateTime?

  tripId       String
  trip         IntercityTrip            @relation(fields: [tripId], references: [id])

  orderId      String
  order        IntercityOrder           @relation(fields: [orderId], references: [id])

  status       IntercityTripInviteStatus @default(PENDING)
  seatsOffered Int                      @default(1)
  priceOffered Decimal                  @db.Decimal(10, 2)
  message      String?

  @@index([tripId, status])
  @@index([orderId, status])
}

model IntercityTripStatusHistory {
  id                String               @id @default(cuid())
  intercityTripId   String
  intercityTrip     IntercityTrip        @relation(fields: [intercityTripId], references: [id])

  status            IntercityTripStatus
  createdAt         DateTime             @default(now())
}
