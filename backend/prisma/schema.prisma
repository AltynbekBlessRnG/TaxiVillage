generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Общий пользователь системы
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phone     String   @unique
  email     String?  @unique
  password  String

  /// passenger | driver | admin
  role      UserRole

  passenger PassengerProfile?
  driver    DriverProfile?
}

/// Профиль пассажира
model PassengerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  fullName  String?

  rides     Ride[]   @relation("PassengerRides")
  favoriteAddresses FavoriteAddress[]
  sentMessages     Message[]     @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
}

/// Профиль водителя
model DriverProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])

  fullName     String?
  status       DriverStatus  @default(PENDING) // PENDING / APPROVED / REJECTED
  isOnline     Boolean       @default(false)

  lat          Float?
  lng          Float?
  lastRideFinishedAt DateTime?
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  rating       Float         @default(5.0)

  car          Car?
  rides        Ride[]        @relation("DriverRides")
  documents    DriverDocument[]
}

/// Автомобиль водителя
model Car {
  id           String         @id @default(cuid())
  driverId     String         @unique
  driver       DriverProfile  @relation(fields: [driverId], references: [id])

  make         String
  model        String
  color        String
  plateNumber  String
}

/// Документы водителя (права, СТС, лицензия и т.п.)
model DriverDocument {
  id          String         @id @default(cuid())
  driverId    String
  driver      DriverProfile  @relation(fields: [driverId], references: [id])

  type        DocumentType
  url         String
  uploadedAt  DateTime       @default(now())
  approved    Boolean        @default(false)
}

/// Тариф
model Tariff {
  id               String   @id @default(cuid())
  name             String
  baseFare         Decimal  @db.Decimal(10, 2) // базовая стоимость посадки
  pricePerKm       Decimal  @db.Decimal(10, 2)
  pricePerMinute   Decimal? @db.Decimal(10, 2)

  systemCommissionPercent Int @default(10)

  isActive         Boolean  @default(true)

  rides            Ride[]
}

/// Поездка
model Ride {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  passengerId      String
  passenger        PassengerProfile @relation("PassengerRides", fields: [passengerId], references: [id])

  driverId         String?
  driver           DriverProfile?   @relation("DriverRides", fields: [driverId], references: [id])

  tariffId         String
  tariff           Tariff          @relation(fields: [tariffId], references: [id])

  status           RideStatus      @default(SEARCHING_DRIVER)

  paymentMethod    PaymentMethod    @default(CARD)

  fromAddress      String
  fromLat          Float
  fromLng          Float

  toAddress        String
  toLat            Float
  toLng            Float

  // Промежуточные остановки
  stops            RideStop[]

  estimatedPrice   Decimal?        @db.Decimal(10, 2)
  finalPrice       Decimal?        @db.Decimal(10, 2)

  startedAt        DateTime?
  finishedAt       DateTime?

  commissionAmount Decimal?        @db.Decimal(10, 2)
  driverRating     Int?

  statusHistory    RideStatusHistory[]
  messages        Message[]
}

/// Остановка поездки
model RideStop {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])

  address   String
  lat       Float
  lng       Float

  createdAt DateTime @default(now())
}

/// История изменения статусов поездки
model RideStatusHistory {
  id        String      @id @default(cuid())
  rideId    String
  ride      Ride        @relation(fields: [rideId], references: [id])

  status    RideStatus
  createdAt DateTime    @default(now())
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideStatus {
  SEARCHING_DRIVER
  DRIVER_ASSIGNED
  ON_THE_WAY
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum DocumentType {
  DRIVER_LICENSE
  CAR_REGISTRATION
  TAXI_LICENSE
  OTHER
}

enum MessageSender {
  PASSENGER
  DRIVER
}

enum PaymentMethod {
  CARD
  CASH
}

/// Избранные адреса пассажира
model FavoriteAddress {
  id          String   @id @default(cuid())
  passengerId String
  passenger   PassengerProfile @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  
  name        String   // "Дом", "Работа", "Спортзал"
  address     String   // Полный адрес
  lat         Float
  lng         Float
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([passengerId, name])
}

/// Сообщения в чате между водителем и пассажиром
model Message {
  id          String   @id @default(cuid())
  rideId      String
  ride        Ride     @relation(fields: [rideId], references: [id])
  
  // Отправитель
  senderId    String
  senderType  MessageSender
  sender      PassengerProfile? @relation("SentMessages", fields: [senderId], references: [id])
  
  // Получатель
  receiverId  String
  receiverType MessageSender
  receiver    PassengerProfile? @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  content     String
  createdAt   DateTime @default(now())
  
  @@index([rideId, createdAt])
}

